<!DOCTYPE html>
<html>

<head>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <%- include("partials/header.ejs") %>
        <div class="container--item">
            <h2><%= item.name %></h2>
            <a class="back" href="/category/<%= item.categoryid %>">See this category</a>
            <p><%= item.description %></p>
            <p>Quantity: <%= item.quantity %></p>
            <a href="/edititem/<%= item.id %>" class="btn">Edit item</a>
        </div>
</body>

</html>